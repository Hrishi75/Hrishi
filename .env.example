# Spotify "now playing" integration.
# Copy this file to .env.local and fill in the values (.env.local is gitignored).
#
# 1. Create an app at https://developer.spotify.com/dashboard
#    - Add Redirect URI: http://127.0.0.1:8888/callback
# 2. Put the Client ID / Secret below.
# 3. Run: node scripts/spotify-refresh-token.mjs
#    Authorize in the browser, then copy the printed refresh token here.

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
